## ===================================================================
## Section 4: Invisible / zero-width Unicode characters
## ===================================================================
printf '%s\n' ""
printf '%s\n' "--- Invisible / zero-width Unicode characters ---"

## U+200B ZERO WIDTH SPACE -> E2 80 8B
f="$(write_file_binary "zwsp.txt" 'ab\xE2\x80\x8Bcd')"
