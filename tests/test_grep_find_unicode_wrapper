expect_detected "U+03BF GREEK SMALL OMICRON (looks like Latin o)" "$f"

## U+FF21 FULLWIDTH A -> EF BC A1
f="$(write_file_binary "fullwidth_A.txt" '\xEF\xBC\xA1dmin')"
