#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## Exit non-zero after the first failed plugin.

set -o errexit
set -o nounset
set -o errtrace
set -o pipefail

# shellcheck source=../libexec/helper-scripts/log_run_die.sh
source /usr/libexec/helper-scripts/log_run_die.sh

run_plugin_command() {
  local plugin_cmd plugin_args

  plugin_cmd="$1"
  shift
  plugin_args=( "$@" )

  if (( ${#plugin_args[@]} == 0 )); then
    ## captured_stdin inherited from text_safety_scan function.
    "${plugin_cmd}" < "${captured_stdin_file}"
  else
    "${plugin_cmd}" "${plugin_args[@]}"
  fi
}

cleanup() {
  local _exit_code="${1:-$?}"
  trap - EXIT
  ## captured_stdin_file is inherited from text_safety_scan function.
  ## captured_stdin_file is set prior setting up the 'trap'.
  safe-rm -f -- "${captured_stdin_file}"
  exit "${_exit_code}"
}

text_safety_scan() {
  local file_list captured_stdin_file file_name plugin_list plugin_item

  file_list=( "$@" )
  plugin_list=( 'unicode-show' 'modeline-show' )

  if (( ${#file_list[@]} == 0 )); then
    if [[ -t 0 ]]; then
      die 1 'No input files and stdin is a terminal.'
    fi
    ## Using a temp file rather than capturing to a variable because Bash will
    ## strip trailing newlines from captured text, potentially distorting the
    ## results of the check.
    if ! captured_stdin_file="$(mktemp)"; then
      die 1 'Could not create temporary file for capturing stdin!'
    fi
    trap 'cleanup' EXIT

    cat | sponge -- "${captured_stdin_file}"

    for plugin_item in "${plugin_list[@]}"; do
      run_plugin_command "${plugin_item}"
    done

    cleanup
  else
    for file_name in "${file_list[@]}"; do
      if ! test -r "$file_name"; then
        die 1 "File '$file_name' does not exist or is not readable!"
      fi
      for plugin_item in "${plugin_list[@]}"; do
        run_plugin_command "${plugin_item}" "${file_name}"
      done
    done
  fi
}

text_safety_scan "$@"
