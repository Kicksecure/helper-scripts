## Provides rm-safe-maybe function.
## Uses safe-rm if installed, otherwise falls back to rm.

rm-safe-maybe() {
  if command -v safe-rm >/dev/null 2>&1 ; then
    safe-rm "$@"
  else
    rm "$@"
  fi
}
